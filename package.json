{
  "name": "bsky-cli",
  "version": "0.3.0",
  "description": "A CLI client for Bluesky",
  "type": "module",
  "bin": {
    "bsky": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "link:global": "yarn build && npm link",
    "unlink:global": "npm unlink -g bsky-cli"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.12.0",
  "license": "MIT",
  "dependencies": {
    "@atproto/api": "^0.19.1",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/ws": "^8",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

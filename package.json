{
  "name": "@harveyrandall/bsky-cli",
  "version": "1.0.0",
  "description": "A CLI client for Bluesky",
  "type": "module",
  "bin": {
    "bsky": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "link:global": "yarn build && npm link",
    "unlink:global": "npm unlink -g @harveyrandall/bsky-cli",
    "prepublishOnly": "yarn typecheck && yarn test:run && yarn build",
    "publish:npm": "npm publish --access public"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.12.0",
  "license": "MIT",
  "homepage": "https://github.com/harveyrandall/bsky-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harveyrandall/bsky-cli.git"
  },
  "bugs": {
    "url": "https://github.com/harveyrandall/bsky-cli/issues"
  },
  "keywords": [
    "bluesky",
    "bsky",
    "atproto",
    "cli",
    "social",
    "command-line"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@atproto/api": "^0.19.1",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/ws": "^8",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
